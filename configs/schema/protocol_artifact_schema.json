  "run_manifest_record": {
    "required_fields": [
      "run_id",
      "created_at",
      "construction_phase",
      "protocol_name",
      "method_config_digest",
      "protocol_config_digest",
      "attack_matrix_digest",
      "ablation_config_digest",
      "records_digest",
      "thresholds_digest",
      "tables_digest",
      "figures_digest_placeholder",
      "placeholder_fields",
      "random_fields"
    ]
  },
  "tables": {
    "main_metrics_columns": [
      "run_id",
      "method_family",
      "method_variant",
      "target_fpr",
      "threshold_id",
      "split",
