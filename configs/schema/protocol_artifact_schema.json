      "sample_id",
      "split",
      "sample_role",
      "method_family",
      "method_variant",
      "attack_name",
      "attack_params",
      "target_fpr",
      "threshold_id",
      "input_artifact_trace",
      "latent_backend_name",
      "latent_backend_status",
      "latent_tensor_digest_random",
      "latent_generation_seed_random",
      "evidence_scores",
      "disabled_evidence",
      "decision",
      "failure_reason",
      "placeholder_fields",
      "random_fields"
    ],
    "required_evidence_score_fields": [
      "S_tubelet",
      "S_sync",
      "S_traj",
      "S_final"
    ],
    "required_input_artifact_trace_fields": [
      "artifact_kind",
      "backend_name",
      "backend_status",
      "artifact_digest",
      "generation_seed_random"
