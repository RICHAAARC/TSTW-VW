      "attacked_negative_FPR",
      "clean_positive_TPR",
      "attacked_positive_TPR"
    ],
    "ablation_table_columns": [
      "run_id",
      "method_family",
      "method_variant",
      "enabled_tubelet_evidence",
      "enabled_sync_evidence",
      "enabled_trajectory_evidence",
      "fusion_rule",
      "threshold_id",
      "clean_negative_FPR",
      "attacked_negative_FPR",
      "clean_positive_TPR",
      "attacked_positive_TPR"
    ]
