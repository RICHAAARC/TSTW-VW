{
  "project_stage": "protocol_skeleton",
  "construction_phase": "protocol_skeleton",
  "protocol_name": "fixed_low_fpr_calibrated_detection",
  "record_schema_name": "event_score_record",
  "threshold_schema_name": "threshold_record",
  "manifest_schema_name": "run_manifest_record",
  "output_layout": {
    "event_scores_path": "records/event_scores.jsonl",
