      "failure_reason",
      "S_tubelet",
      "S_sync",
      "S_traj"
    ]
  },
  "threshold_record": {
    "required_fields": [
      "threshold_id",
      "run_id",
      "method_family",
      "method_variant",
      "score_name",
      "target_fpr",
